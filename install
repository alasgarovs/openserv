#!/bin/bash
set -e

# check required commands first
command -v tar >/dev/null || { echo "tar is required"; exit 1; }
command -v curl >/dev/null || { echo "curl is required"; exit 1; }

REPO="https://github.com/alasgarovs/llamaorch"
BRANCH="main"

echo "[*] Installing LlamaOrch..."

TMP_DIR="$(mktemp -d)"

cleanup() {
    rm -rf "$TMP_DIR"
}
trap cleanup EXIT

ARCHIVE_URL="$REPO/archive/refs/heads/$BRANCH.tar.gz"

# Download
curl -fsSL "$ARCHIVE_URL" -o "$TMP_DIR/llamaorch.tar.gz"

# Extract
tar -xzf "$TMP_DIR/llamaorch.tar.gz" -C "$TMP_DIR"

# Detect extracted directory (GitHub format: repo-branch)
EXTRACTED_DIR="$(find "$TMP_DIR" -maxdepth 1 -type d -name "llamaorch-*")"

# Run installer
bash "$EXTRACTED_DIR/src/configure"

echo "[✓] LlamaOrch installed successfully!"